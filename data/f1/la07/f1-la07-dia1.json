  "lines": [
    { "text": "Teacher: Tell me about yourself and your family.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-sen-tell-me-about-yourself-and-your-family.mp3" },
    { "text": "Nick: Hello.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n1-hello.mp3" },
    { "text": "My name is Nick.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n2-my-name-is-nick.mp3" },
    { "text": "I am eight years old.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n3-i-am-eight-years-old.mp3" },
    { "text": "I am happy.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n4-i-am-happy.mp3" },
    { "text": "This is my family.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n5-this-is-my-family.mp3" },
    { "text": "This is my mother. She is young.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n6-this-is-my-mother-she-is-young.mp3" },
    { "text": "This is my father. He is tall.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n7-this-is-my-father-he-is-tall.mp3" },
    { "text": "This is my grandmother. She is fat.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n8-this-is-my-grandmother-she-is-fat.mp3" },
    { "text": "This is my grandfather. He is old.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n9-this-is-my-grandfather-he-is-old.mp3" },
    { "text": "This is my brother. He is thin.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n10-this-is-my-brother-he-is-thin.mp3" },
    { "text": "This is my sister. She is short.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n11-this-is-my-sister-she-is-short.mp3" },
    { "text": "And I am short, too.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n12-and-i-am-short-too.mp3" },
    { "text": "I love my family.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n13-i-love-my-family.mp3" },
    { "text": "Thank you.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la07/f1-la07-dia1-n14-thank-you.mp3" }
  ]
}
