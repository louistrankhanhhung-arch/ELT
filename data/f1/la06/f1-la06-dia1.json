  "lines": [
    { "text": "Teacher: Tell me about your family.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-sen-tell-me-about-yourself-and-your-family.mp3" },
    { "text": "Nick: Hello.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n1-hello.mp3" },
    { "text": "My name is Nick.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n2-my-name-is-nick.mp3" },
    { "text": "I am eight years old.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n3-i-am-eight-years-old.mp3" },
    { "text": "I am happy.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n4-i-am-happy.mp3" },
    { "text": "This is my family.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n5-this-is-my-family.mp3" },
    { "text": "This is my mother.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n6-this-is-my-mother.mp3" },
    { "text": "This is my father.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n7-this-is-my-father.mp3" },
    { "text": "She is my grandmother.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n8-she-is-my-grandmother.mp3" },
    { "text": "He is my grandfather.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n9-he-is-my-grandfather.mp3" },
    { "text": "She is my sister.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n10-she-is-my-sister.mp3" },
    { "text": "He is my brother.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n11-he-is-my-brother.mp3" },
    { "text": "And he is a baby.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n12-and-he-is-a-baby.mp3" },
    { "text": "I love my family.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n13-i-love-my-family.mp3" },
    { "text": "Thank you.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/f1/la06/f1-la06-dia1-n14-thank-you.mp3" }
  ]
