    { "text": "After that, I play with my friends in the playground.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-a6-after-that-i-play-with-my-friends-in-the-playground.mp3" },
    { "text": "Finally, I go home.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-a7-finally-i-go-home.mp3" }
