    { "text": "A: Hello, Amy.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-t1-hello-amy.mp3" },
    { "text": "B: Hello, Tony.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-a1-hello-tony.mp3" },
    { "text": "A: What is your favorite subject?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-t2-what-is-your-favorite-subject.mp3" },
    { "text": "B: My favorite subject is English.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-a2-my-favorite-subject-is-english.mp3" },
    { "text": "A: Why do you like English?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-t3-why-do-you-like-english.mp3" },
    { "text": "B: I like English because it is fun.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-a3-i-like-english-because-it-is-fun.mp3" },
    { "text": "A: What do you do at school?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-t4-what-do-you-do-at-school.mp3" },
    { "text": "B: First, I go to school.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-a4-first-i-go-to-school.mp3" },
    { "text": "B: Then I study English in the classroom.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-a5-then-i-study-english-in-the-classroom.mp3" },
    { "text": "B: After that, I play with my friends in the playground.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-a6-after-that-i-play-with-my-friends-in-the-playground.mp3" },
    { "text": "B: Finally, I go home.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l09/r2-l09-dia1-a7-finally-i-go-home.mp3" }
