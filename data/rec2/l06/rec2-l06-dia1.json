  "lines": [
    { "text": "A: Hello, Tony.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-a1-hello-tony.mp3" },
    { "text": "B: Hello, Amy.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-t1-hello-amy.mp3" },
    { "text": "A: Can you tell me about your family?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-a2-can-you-tell-me-about-your-family.mp3" },
    { "text": "B: Sure. There are five people in my family.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-t2-sure-there-are-five-people-in-my-family.mp3" },
    { "text": "B: I live with my parents, brother and sister.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-t3-i-live-with-my-parents-brother-and-sister.mp3" },
    { "text": "B: My father is a doctor.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-t4-my-father-is-a-doctor.mp3" },
    { "text": "B: My mother is a shopkeeper.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-t5-my-mother-is-a-shopkeeper.mp3" },
    { "text": "A: Wow! What is your father like?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-a3-wow-what-is-your-father-like.mp3" },
    { "text": "B: He is strict.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-t6-he-is-strict.mp3" },
    { "text": "A: What is your mother like?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-a4-what-is-your-mother-like.mp3" },
    { "text": "B: She is hardworking.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-t7-she-is-hardworking.mp3" },
    { "text": "A: What about your brother and sister?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-a5-what-about-your-brother-and-sister.mp3" },
    { "text": "B: My brother is smart.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-t8-my-brother-is-smart.mp3" },
    { "text": "B: My sister is helpful.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-t9-my-sister-is-helpful.mp3" },
    { "text": "A: That’s great!", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l06/r2-l06-dia1-a6-thats-great.mp3" }
  ]
}
