  "lines": [
    { "text": "A: Hello, Bill.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-a1-hello-bill.mp3" },
    { "text": "B: Hello, Amy.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-b1-hello-amy.mp3" },
    { "text": "A: What do you do on weekdays?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-a2-what-do-you-do-on-weekdays.mp3" },
    { "text": "B: First, I get up.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-b2-first-i-get-up.mp3" },
    { "text": "B: Then, I have breakfast.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-b3-then-i-have-breakfast.mp3" },
    { "text": "B: After that, I go to school.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-b4-after-that-i-go-to-school.mp3" },
    { "text": "A: What do you do in the afternoon?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-a3-what-do-you-do-in-the-afternoon.mp3" },
    { "text": "B: I go home. Then, I play football.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-b5-i-go-home-then-i-play-football.mp3" },
    { "text": "A: What do you do in the evening?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-a4-what-do-you-do-in-the-evening.mp3" },
    { "text": "B: I take a shower.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-b6-1-i-take-a-shower.mp3" },
    { "text": "B: Then, I have dinner at 6 o’clock.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-b6-2-then-i-have-dinner-at-6-oclock.mp3" },
    { "text": "A: What do you do at night?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-a5-what-do-you-do-at-night.mp3" },
    { "text": "B: I do my homework. Finally, I go to bed.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-b7-i-do-my-homework-finally-i-go-to-bed.mp3" },
    { "text": "A: Nice!", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l03/r2-l03-dia1-a6-nice.mp3" }
  ]
}
