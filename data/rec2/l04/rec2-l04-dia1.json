  "lines": [
    { "text": "Hello. My name is Bill.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l04/r2-l04-dia1-b1-hello-my-name-is-bill.mp3" },
    { "text": "Let me tell you about my daily life.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l04/r2-l04-dia1-b2-let-me-tell-you-about-my-daily-life.mp3" },
    { "text": "First, I get up at six o'clock in the morning.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l04/r2-l04-dia1-b3-first-i-get-up-at-six-oclock-in-the-morning.mp3" },
    { "text": "Then, I brush my teeth and wash my face.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l04/r2-l04-dia1-b4-then-i-brush-my-teeth-and-wash-my-face.mp3" },
    { "text": "After that, I have breakfast with my family.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l04/r2-l04-dia1-b5-after-that-have-breakfast-with-my-family.mp3" },
    { "text": "Next, I go to school and study with my friends.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l04/r2-l04-dia1-b6-next-i-go-to-school-and-study-with-my-friends.mp3" },
    { "text": "After school, I play football and take a shower.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l04/r2-l04-dia1-b7-after-school-i-play-football-and-take-a-shower.mp3" },
    { "text": "In the evening, I have dinner and do my homework.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l04/r2-l04-dia1-b8-in-the-evening-i-have-dinner-and-do-my-homework.mp3" },
    { "text": "Finally, I play games and go to bed at nine o'clock.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l04/r2-l04-dia1-b9-finally-i-play-games-and-go-to-bed-at-nine-oclock.mp3" },
    { "text": "That's my daily life. Thank you!", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l04/r2-l04-dia1-b10-after-thats-my-daily-life-thank-you.mp3" }
  ]
}
