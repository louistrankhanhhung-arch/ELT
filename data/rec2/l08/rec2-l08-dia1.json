  "lines": [
    { "text": "Hello.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-dia1-t1-hello.mp3" },
    { "text": "Let me tell you about my family.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-dia1-t2-let-me-tell-you-about-my-family.mp3" },
    { "text": "There are five people in my family.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-dia1-t3-there-are-five-people-in-my-family.mp3" },
    { "text": "I live with my parents, my brother and my sister.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-dia1-t4-i-live-with-my-parents-my-brother-and-my-sister.mp3" },
    { "text": "My father is a doctor. He is strict.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-dia1-t5-my-father-is-a-doctor-he-is-strict.mp3" },
    { "text": "My mother is a shopkeeper. She is hardworking.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-dia1-t6-my-mother-is-a-shopkeeper-she-is-hardworking.mp3" },
    { "text": "My brother is a student. He is smart.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-dia1-t7-my-brother-is-a-student-he-is-smart.mp3" },
    { "text": "My sister is a student, too. She is helpful.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-dia1-t8-my-sister-is-a-student-too-she-is-helpfull.mp3" },
    { "text": "I love my family.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-dia1-t9-i-love-my-family.mp3" },
    { "text": "Thank you.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-dia1-t10-thank-you.mp3" }
  ]
}
