    { "text": "Answer these questions and take note.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-sen-answer-these-questions-and-take-note.mp3" },
    { "text": "You have an example.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-sen-you-have-an-example.mp3" },
    { "text": "1. How many people are there in your family?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-sen-1-how-many-people-are-there-in-your-family.mp3" },
    { "text": "2. Who do you live with?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-sen-2-who-do-you-live-with.mp3" },
    { "text": "3. What does your father do? What is he like?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-sen-3-what-does-your-father-do-what-is-he-like.mp3" },
    { "text": "4. What does your mother do? What is she like?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-sen-4-what-does-your-mother-do-what-is-she-like.mp3" },
    { "text": "5. What does your brother do? What is he like?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-sen-5-what-does-your-brother-do-what-is-he-like.mp3" },
    { "text": "6. What does your sister do? What is she like?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l08/r2-l08-sen-6-what-does-your-sister-do-what-is-she-like.mp3" }
