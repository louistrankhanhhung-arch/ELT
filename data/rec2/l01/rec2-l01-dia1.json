    { "text": "A: Hello, Bill.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l01/r2-l01-dia1-t1-hello-bill.mp3" },
    { "text": "B: Hello, Tony.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l01/r2-l01-dia1-b1-hello-tony.mp3" },
    { "text": "A: What do you do in the morning?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l01/r2-l01-dia1-t2-what-do-you-do-in-the-morning.mp3" },
    { "text": "B: I get up. I have breakfast. I go to school.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l01/r2-l01-dia1-b2-i-get-up-i-have-breakfast-i-go-to-school.mp3" },
    { "text": "A: What do you do after school?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l01/r2-l01-dia1-t3-what-do-you-do-after-school.mp3" },
    { "text": "B: Sorry? Can you repeat?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l01/r2-l01-dia1-b3-sorry-can-you-repeat.mp3" },
    { "text": "A: What do you do after school?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l01/r2-l01-dia1-t3-what-do-you-do-after-school.mp3" },
    { "text": "B: I go home.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l01/r2-l01-dia1-b4-i-go-home.mp3" },
    { "text": "A: What do you do after that?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l01/r2-l01-dia1-t4-what-do-you-do-after-that.mp3" },
    { "text": "B: I do my homework.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l01/r2-l01-dia1-b5-i-do-my-homework.mp3" },
    { "text": "A: What do you do at night?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l01/r2-l01-dia1-t5-what-do-you-do-at-night.mp3" },
    { "text": "B: I go to bed.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/r2/l01/r2-l01-dia1-b6-i-go-to-bed.mp3" }
