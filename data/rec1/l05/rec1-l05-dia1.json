    { "text": "A: Wow! Ducks can swim. Can you swim?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l05/g1-l05-dia1-t4-wow-ducks-can-swim-can-you-swim.mp3" },
    { "text": "B: Yes, I can. And I can dance, too.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l05/g1-l05-dia1-j4-yes-i-can-and-i-can-dance-too.mp3" }
