  "lines": [
    { "text": "A: Welcome to my school, Jill!", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l10/g1-l10-dia1-a1-welcome-to-my-school-jill.mp3" },
    { "text": "B: Wow! It is big.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l10/g1-l10-dia1-j1-wow-it-is-big.mp3" },
    { "text": "A: This is a classroom.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l10/g1-l10-dia1-a2-this-is-a-classroom.mp3" },
    { "text": "B: Nice.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l10/g1-l10-dia1-j2-nice.mp3" },
    { "text": "A: There is a playground over there.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l10/g1-l10-dia1-a3-there-is-a-playground-over-there.mp3" },
    { "text": "B: Oh! There is a bicycle in the playground.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l10/g1-l10-dia1-j3-oh-there-is-a-playground-over-there.mp3" },
    { "text": "A: Yes. And there is a ball, too.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l10/g1-l10-dia1-a4-yes-and-there-is-a-ball-too.mp3" },
    { "text": "B: Where is the ball?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l10/g1-l10-dia1-j4-where-is-the-ball.mp3" },
    { "text": "A: It is next to the bicycle.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l10/g1-l10-dia1-a5-it-is-next-to-the-bicycle.mp3" },
    { "text": "B: Cool!", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l10/g1-l10-dia1-j5-cool.mp3" },
    { "text": "A: And that is a garden.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l10/g1-l10-dia1-a6-and-that-is-a-garden.mp3" },
    { "text": "B: It is beautiful.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l10/g1-l10-dia1-j6-it-is-beautiful.mp3" }
  ]
}
