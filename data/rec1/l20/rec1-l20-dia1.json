  "lines": [
    { "text": "A: Hello, Tom.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l20/g1-l20-dia1-b1-who-is-she.mp3" },
    { "text": "B: Hello, Ben.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l20/g1-l20-dia1-t1-she-is-my-sister.mp3" },
    { "text": "A: Where is your father?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l20/g1-l20-dia1-b2-is-she-kind.mp3" },
    { "text": "B: He is in the garden.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l20/g1-l20-dia1-t2-yes-she-is.mp3" },
    { "text": "A: Where is your sister?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l20/g1-l20-dia1-b3-what-does-she-like.mp3" },
    { "text": "B: She is in the classroom.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l20/g1-l20-dia1-t3-she-likes-apples.mp3" },
    { "text": "A: Where is your dog?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l20/g1-l20-dia1-b4-what-can-she-do.mp3" },
    { "text": "B: It is under the table.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l20/g1-l20-dia1-t4-she-can-dance.mp3" },
    { "text": "A: Look! What is that in the tree?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l20/g1-l20-dia1-b5-great.mp3" },
    { "text": "B: It is my kite.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l20/g1-l20-dia1-t5-she-can-dance.mp3" },
    { "text": "A: Oh no.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l20/g1-l20-dia1-b6-great.mp3" }
  ]
