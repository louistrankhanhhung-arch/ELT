  "lines": [
    { "text": "A: What is this, Tom?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l11/g1-l11-dia1-b1-what-is-this-tom.mp3" },
    { "text": "B: It is my family photo.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l11/g1-l11-dia1-t1-it-is-my-family-photo.mp3" },
    { "text": "A: Wow! Who is he?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l11/g1-l11-dia1-b2-wow-who-is-he.mp3" },
    { "text": "B: He is my father.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l11/g1-l11-dia1-t2-he-is-my-father.mp3" },
    { "text": "A: And who is she?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l11/g1-l11-dia1-b3-and-who-is-she.mp3" },
    { "text": "B: She is my mother.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l11/g1-l11-dia1-t3-she-is-my-mother.mp3" },
    { "text": "A: Who is he?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l11/g1-l11-dia1-b4-who-is-he.mp3" },
    { "text": "B: He is my brother.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l11/g1-l11-dia1-t4-he-is-my-brother.mp3" },
    { "text": "A: Who is she?", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l11/g1-l11-dia1-b5-who-is-she.mp3" },
    { "text": "B: She is my sister.", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l11/g1-l11-dia1-t5-she-is-my-sister.mp3" },
    { "text": "A: Nice family!", "audio": "https://pub-af09166f1dd74d53a2042fd46f7462d7.r2.dev/g1/l11/g1-l11-dia1-b6-nice-family.mp3" },
